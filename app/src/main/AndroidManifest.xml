<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ⚠️ OBLIGATORIO para la conexión a MySQL vía HTTP -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TriviaGame.Launcher"
        android:usesCleartextTraffic="true"
        tools:targetApi="31"
        android:name=".TriviaApp">


        <!--
             android:usesCleartextTraffic="true"
             Solo necesario si tu servidor usa HTTP (no HTTPS).
             En producción, usa HTTPS y elimina esta línea.
        -->

        <activity
            android:name=".exec.InicioActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".exec.LoginActivity" />
        <activity android:name=".exec.RegistroActivity" />
        <activity android:name=".exec.MenuActivity" />
        <activity android:name=".exec.JuegoActivity" />
        <activity android:name=".exec.ResultadoActivity" />
        <activity android:name=".exec.RankingActivity" />
        <activity android:name=".exec.AjustesActivity" />

    </application>

</manifest>
