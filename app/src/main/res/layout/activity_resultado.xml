<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgMainGame">

    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/circle_glow"
        android:alpha="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-100dp" />

    <TextView
        android:id="@+id/tvResultadoMensaje"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Excelente! 🌟"
        android:textColor="?attr/colorAccentGame"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="72dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvResultadoCategoria"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HISTORIA"
        android:textColor="?attr/textSecondaryGame"
        android:textSize="14sp"
        android:letterSpacing="0.15"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvResultadoMensaje"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardPuntuacion"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="100dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="?attr/colorAccentGame"
        app:layout_constraintTop_toBottomOf="@id/tvResultadoCategoria"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PUNTOS"
                android:textColor="#1A1A2E"
                android:textSize="12sp"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/tvResultadoPuntuacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#1A1A2E"
                android:textSize="52sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvMejorPuntuacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mejor puntuación: 0"
        android:textColor="?attr/textSecondaryGame"
        android:textSize="15sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardPuntuacion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnJugarOtraVez"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:text="🔄  JUGAR DE NUEVO"
        android:textColor="#1A1A2E"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="?attr/colorAccentGame"
        app:cornerRadius="28dp"
        android:elevation="6dp"
        app:layout_constraintBottom_toTopOf="@id/btnVolverMenu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnVolverMenu"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:text="🏠  VOLVER AL MENÚ"
        android:textColor="?attr/textPrimaryGame"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="?attr/cardBackgroundGame"
        app:cornerRadius="28dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
