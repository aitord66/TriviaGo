<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgMainGame">

    <!-- ── HEADER ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/headerJuego"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvJuegoCategoria"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HISTORIA"
            android:textColor="?attr/colorAccentGame"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/tvNumeroPregunta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 8"
            android:textColor="?attr/textSecondaryGame"
            android:textSize="14sp"
            android:layout_marginEnd="16dp" />

        <TextView
            android:id="@+id/tvPuntuacionJuego"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ 0"
            android:textColor="?attr/textPrimaryGame"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ── TEMPORIZADOR ──────────────────────────── -->
    <FrameLayout
        android:id="@+id/timerFrame"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/headerJuego"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressTiempo"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_gravity="center_vertical"
            android:progressDrawable="@drawable/progress_timer"
            android:max="20000"
            android:progress="20000" />

        <TextView
            android:id="@+id/tvTiempo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:text="20"
            android:textColor="?attr/colorAccentGame"
            android:textSize="12sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- ── CARD PREGUNTA (imagen + texto) ──────── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPregunta"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="?attr/cardBackgroundGame"
        app:layout_constraintTop_toBottomOf="@id/timerFrame"
        app:layout_constraintBottom_toTopOf="@id/tvFeedback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Imagen de la pregunta -->
            <ImageView
                android:id="@+id/ivPreguntaImagen"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:scaleType="centerCrop"
                android:contentDescription="Imagen de la pregunta"
                android:background="?attr/cardBackgroundGame"
                android:visibility="gone" />

            <!-- Enunciado -->
            <TextView
                android:id="@+id/tvEnunciado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="0"
                android:gravity="center"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:text="¿En qué año se descubrió América?"
                android:textColor="?attr/textPrimaryGame"
                android:textSize="18sp"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ── FEEDBACK ───────────────────────────── -->
    <TextView
        android:id="@+id/tvFeedback"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/gridOpciones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardPregunta" />

    <!-- ── BOTONES OPCIONES ───────────────────── -->
    <GridLayout
        android:id="@+id/gridOpciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnOpcion1"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="Opción A"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="?attr/btnOpcionTint"
            android:onClick="onOpcionClick"
            app:cornerRadius="16dp"
            android:elevation="4dp" />

        <Button
            android:id="@+id/btnOpcion2"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="Opción B"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="?attr/btnOpcionTint"
            android:onClick="onOpcionClick"
            app:cornerRadius="16dp"
            android:elevation="4dp" />

        <Button
            android:id="@+id/btnOpcion3"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="Opción C"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="?attr/btnOpcionTint"
            android:onClick="onOpcionClick"
            app:cornerRadius="16dp"
            android:elevation="4dp" />

        <Button
            android:id="@+id/btnOpcion4"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="Opción D"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="?attr/btnOpcionTint"
            android:onClick="onOpcionClick"
            app:cornerRadius="16dp"
            android:elevation="4dp" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
