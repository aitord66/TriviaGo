<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgMainGame">

    <ImageButton
        android:id="@+id/btnVolverAjustes"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:background="?attr/cardBackgroundGame"
        android:tint="?attr/textPrimaryGame"
        android:contentDescription="Volver"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvAjustesTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️  Ajustes"
        android:textColor="?attr/textPrimaryGame"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardUser"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="?attr/cardBackgroundGame"
        app:layout_constraintTop_toBottomOf="@id/tvAjustesTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="🎮"
                android:textSize="32sp"
                android:gravity="center"
                android:background="@drawable/circle_icon_bg" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jugador"
                    android:textColor="?attr/textSecondaryGame"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvAjustesUser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textColor="?attr/textPrimaryGame"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardTema"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="?attr/cardBackgroundGame"
        app:layout_constraintTop_toBottomOf="@id/cardUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎨"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tema de la app"
                    android:textColor="?attr/textPrimaryGame"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <RadioGroup
                android:id="@+id/rgTema"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rbDark"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="🌙  Oscuro  (predeterminado)"
                    android:textColor="?attr/textPrimaryGame"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:buttonTint="?attr/colorAccentGame"
                    android:background="@drawable/radio_option_bg"
                    android:layout_marginBottom="8dp" />

                <RadioButton
                    android:id="@+id/rbLight"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="☀️  Claro"
                    android:textColor="?attr/textPrimaryGame"
                    android:textSize="14sp"
                    android:gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:buttonTint="?attr/colorAccentGame"
                    android:background="@drawable/radio_option_bg" />

            </RadioGroup>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardCuenta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="?attr/cardBackgroundGame"
        app:layout_constraintTop_toBottomOf="@id/cardTema"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Seguridad de la cuenta"
                    android:textColor="?attr/textPrimaryGame"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <EditText
                android:id="@+id/etContrasenaActual"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Contraseña actual"
                android:textColorHint="?attr/textSecondaryGame"
                android:textColor="?attr/textPrimaryGame"
                android:inputType="textPassword"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/radio_option_bg"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etNuevaContrasena"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Nueva contraseña"
                android:textColorHint="?attr/textSecondaryGame"
                android:textColor="?attr/textPrimaryGame"
                android:inputType="textPassword"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="@drawable/radio_option_bg"
                android:layout_marginBottom="14dp"/>

            <Button
                android:id="@+id/btnCambiarContrasena"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Actualizar Contraseña"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="?attr/colorAccentGame"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="20dp"
        android:text="🚪  Cerrar Sesión"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#C62828"
        app:cornerRadius="28dp"
        android:elevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/cardCuenta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>